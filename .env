# Grand Contract v1.0 — Environment Configuration
# Copy to .env and fill in secrets before running docker compose up

# ── App ────────────────────────────────────────────────────────────
DEBUG=1                          # 1 = everyone is ADMIN, no OAuth
SECRET_KEY=change_me_in_production_min_32_chars

# ── OAuth2 ─────────────────────────────────────────────────────────
OAUTH_PROVIDER=google            # google | yandex
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret
OAUTH_REDIRECT_URI=http://localhost/api/auth/callback

# ── Database ───────────────────────────────────────────────────────
POSTGRES_DB=trafficcounting
POSTGRES_USER=tc_user
POSTGRES_PASSWORD=changeme_secure
DATABASE_URL=postgresql+asyncpg://tc_user:changeme_secure@db:5432/trafficcounting

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Storage paths (inside containers) ─────────────────────────────
VIDEO_DIR=/data/videos
FRAME_DIR=/data/frames
PARQUET_DIR=/data/parquet

# ── GPU / Worker ───────────────────────────────────────────────────
YOLO_MODEL_KEY=yolov8m           # yolov8n | yolov8m | yolov8l | yolov8x
FRAMES_SAMPLE_COUNT=100          # uniform keyframes extracted per video

# ── Frontend (build-time Vite env) ────────────────────────────────
VITE_API_BASE=/api
VITE_OAUTH_PROVIDER=google
